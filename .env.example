# YouTube channels (comma-separated channel IDs — overrides config.py list if set)
# CHANNEL_IDS=UCk-DG0N8StZ0T9Dv8XpVLZw,UCxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Ollama (default) — no API key needed. Ensure "Ollama" is running (system tray).
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=llama3.2

# If you do not set EMAIL_FROM / EMAIL_TO, the app dry-runs automatically.
# Set DRY_RUN=0 when email is ready, or DRY_RUN=1 to never send mail.
# DRY_RUN=1

# ---------------------------------------------------------------------------
# Email — after DRY_RUN=0, set these (Gmail: create an App Password for EMAIL_PASSWORD)
# ---------------------------------------------------------------------------
# EMAIL_FROM=you@gmail.com
# EMAIL_TO=you@gmail.com
# EMAIL_PASSWORD=

# ---------------------------------------------------------------------------
# OpenAI cloud instead of Ollama: use empty OPENAI_BASE_URL and your key.
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
